<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="recover_git_state_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="recover_git_state" name="Recover approved outputs and reconcile Git state" isExecutable="false">
    <bpmn:startEvent id="scope_aligned" name="Recovery scope aligned">
      <bpmn:documentation>The operator approved delivery of the three local outputs and removal of the enumerated stale Git state. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:22-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="22-34" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_inventory</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="revalidate_inventory" name="Revalidate Git inventory">
      <bpmn:documentation>Confirm the approved recovery files remain intact and every cleanup target still satisfies its safety precondition. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:30-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="30-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_inventory</bpmn:incoming>
      <bpmn:outgoing>flow_inventory_prepare</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="prepare_change" name="Create isolated recovery Change">
      <bpmn:documentation>Fetch origin and create a Herdr-managed worktree from explicit origin/main, then transfer the approved outputs and planning records. Evidence: skills/deliver-change/SKILL.md:11-25</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="11-25" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_inventory_prepare</bpmn:incoming>
      <bpmn:outgoing>flow_prepare_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="verification_entry" name="Enter verification">
      <bpmn:documentation>Merge the initial implementation path and any bounded review-fix loop before rerunning verification. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_prepare_entry</bpmn:incoming>
      <bpmn:incoming>flow_fix_entry</bpmn:incoming>
      <bpmn:outgoing>flow_entry_verify</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="verify_recovery" name="Run recovery checks">
      <bpmn:documentation>Verify content equivalence, document structure, TOML parsing, Task/plan linkage, diff hygiene, and recovery independence from the primary checkout. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:30-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="30-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_entry_verify</bpmn:incoming>
      <bpmn:outgoing>flow_verify_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="review_change" name="Run fresh-context review">
      <bpmn:documentation>Delegate one read-only review of the exact uncommitted Change after local checks. Evidence: skills/code-review/SKILL.md:44-68</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="44-68" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_verify_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_decide</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="review_decision" name="Change green?">
      <bpmn:documentation>Only a locally verified Change with no confirmed material findings may be committed. Evidence: skills/code-review/SKILL.md:70-88</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-88" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review_decide</bpmn:incoming>
      <bpmn:outgoing>flow_review_pass</bpmn:outgoing>
      <bpmn:outgoing>flow_review_fix</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_in_scope" name="Fix confirmed in-scope findings">
      <bpmn:documentation>Apply only the smallest causal corrections within the approved boundary, then rerun affected checks and review the delta. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review_fix</bpmn:incoming>
      <bpmn:outgoing>flow_fix_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="publish_change" name="Commit, push, and open PR">
      <bpmn:documentation>Commit the green recovery unit, push it, and open one pull request carrying intent and check evidence. Evidence: skills/deliver-change/SKILL.md:26-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="26-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review_pass</bpmn:incoming>
      <bpmn:outgoing>flow_publish_prove</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="prove_preservation" name="Prove remote preservation">
      <bpmn:documentation>Confirm the pushed branch and pull request contain every approved output before deleting any local recovery source. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:30-33</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="30-33" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_publish_prove</bpmn:incoming>
      <bpmn:outgoing>flow_prove_decide</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="preservation_decision" name="Recovery safely represented?">
      <bpmn:documentation>Cleanup may proceed only when the approved content is independently recoverable from committed and pushed Git state. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:31-33</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="31-33" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_prove_decide</bpmn:incoming>
      <bpmn:outgoing>flow_preserved</bpmn:outgoing>
      <bpmn:outgoing>flow_not_preserved</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="preservation_failed" name="Cleanup blocked">
      <bpmn:documentation>Stop without deleting local state when remote preservation cannot be proven. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:31-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="31-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_not_preserved</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="clean_local_git" name="Remove obsolete local Git state">
      <bpmn:documentation>Clean and synchronize primary main; remove six merged worktrees and branches, three superseded stashes, and all historical WIP refs; do not rescue 8ed35f2. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:33-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="33-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_preserved</bpmn:incoming>
      <bpmn:outgoing>flow_clean_verify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="verify_git_invariants" name="Verify final Git invariants">
      <bpmn:documentation>Freshly check worktree count and cleanliness, local branch containment, stash/WIP absence, main synchronization, remote recovery branch, and orphan non-preservation. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:31-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="31-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_clean_verify</bpmn:incoming>
      <bpmn:outgoing>flow_git_finalize</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="finalize_change" name="Finalize Task and PR checks">
      <bpmn:documentation>Record acceptance evidence, mark the Task Done inside the same Change, push finalization, and pass applicable GitHub checks. Evidence: skills/deliver-change/SKILL.md:32-50</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="32-50" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_git_finalize</bpmn:incoming>
      <bpmn:outgoing>flow_finalize_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="disposition_entry" name="Enter operator disposition">
      <bpmn:documentation>Merge the initial handoff and any later resume before checking the pull request's current disposition. Evidence: skills/deliver-change/SKILL.md:46-66</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="46-66" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_finalize_entry</bpmn:incoming>
      <bpmn:incoming>flow_resume_disposition</bpmn:incoming>
      <bpmn:outgoing>flow_entry_operator</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="operator_disposition" name="Operator reviews PR">
      <bpmn:documentation>Present the durable pull-request page; the operator alone decides whether and when to merge. Evidence: skills/deliver-change/SKILL.md:51-64</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="51-64" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_entry_operator</bpmn:incoming>
      <bpmn:outgoing>flow_operator_decide</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="disposition_decision" name="PR disposition?">
      <bpmn:documentation>A merged or rejected pull request determines the terminal path; a still-open pull request pauses for later operator disposition. Evidence: skills/deliver-change/SKILL.md:60-66</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="60-66" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_operator_decide</bpmn:incoming>
      <bpmn:outgoing>flow_still_open</bpmn:outgoing>
      <bpmn:outgoing>flow_rejected</bpmn:outgoing>
      <bpmn:outgoing>flow_merged</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="await_operator_resume" name="Await later operator disposition">
      <bpmn:documentation>The green pull request remains open until the operator merges, rejects, or resumes the delivery check. Evidence: skills/deliver-change/SKILL.md:60-66</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="60-66" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_still_open</bpmn:incoming>
      <bpmn:outgoing>flow_resume_disposition</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="change_rejected" name="Change rejected">
      <bpmn:documentation>Report the rejection and realign without silently replacing the Task or expanding intent. Evidence: skills/deliver-change/SKILL.md:38-45</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="38-45" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_rejected</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="sync_primary_after_merge" name="Synchronize primary main after merge">
      <bpmn:documentation>Fetch the landed pull request and fast-forward the clean primary checkout so the recovered outputs, including the live Herdr setting, are present on main. Evidence: skills/deliver-change/SKILL.md:63-70</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="63-70" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_merged</bpmn:incoming>
      <bpmn:outgoing>flow_sync_conformance</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="record_conformance" name="Verify landing and record conformance">
      <bpmn:documentation>After merge, verify landed state, account for every plan node, and append the conformance report to the plan document. Evidence: skills/bpmn-plans/SKILL.md:58-69</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="58-69" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_sync_conformance</bpmn:incoming>
      <bpmn:outgoing>flow_conformance_done</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="git_reconciled" name="Outputs live and Git reconciled">
      <bpmn:documentation>The approved outputs are landed, local Git state is clean, and plan conformance is recorded. Evidence: backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md:30-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-13 - Recover-approved-local-outputs-and-reconcile-Git-state.md" lines="30-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_conformance_done</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_inventory" sourceRef="scope_aligned" targetRef="revalidate_inventory" />
    <bpmn:sequenceFlow id="flow_inventory_prepare" sourceRef="revalidate_inventory" targetRef="prepare_change" />
    <bpmn:sequenceFlow id="flow_prepare_entry" sourceRef="prepare_change" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="flow_entry_verify" sourceRef="verification_entry" targetRef="verify_recovery" />
    <bpmn:sequenceFlow id="flow_verify_review" sourceRef="verify_recovery" targetRef="review_change" />
    <bpmn:sequenceFlow id="flow_review_decide" sourceRef="review_change" targetRef="review_decision" />
    <bpmn:sequenceFlow id="flow_review_pass" name="green" sourceRef="review_decision" targetRef="publish_change" />
    <bpmn:sequenceFlow id="flow_review_fix" name="finding" sourceRef="review_decision" targetRef="fix_in_scope" />
    <bpmn:sequenceFlow id="flow_fix_entry" sourceRef="fix_in_scope" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="flow_publish_prove" sourceRef="publish_change" targetRef="prove_preservation" />
    <bpmn:sequenceFlow id="flow_prove_decide" sourceRef="prove_preservation" targetRef="preservation_decision" />
    <bpmn:sequenceFlow id="flow_preserved" name="yes" sourceRef="preservation_decision" targetRef="clean_local_git" />
    <bpmn:sequenceFlow id="flow_not_preserved" name="no" sourceRef="preservation_decision" targetRef="preservation_failed" />
    <bpmn:sequenceFlow id="flow_clean_verify" sourceRef="clean_local_git" targetRef="verify_git_invariants" />
    <bpmn:sequenceFlow id="flow_git_finalize" sourceRef="verify_git_invariants" targetRef="finalize_change" />
    <bpmn:sequenceFlow id="flow_finalize_entry" sourceRef="finalize_change" targetRef="disposition_entry" />
    <bpmn:sequenceFlow id="flow_entry_operator" sourceRef="disposition_entry" targetRef="operator_disposition" />
    <bpmn:sequenceFlow id="flow_operator_decide" sourceRef="operator_disposition" targetRef="disposition_decision" />
    <bpmn:sequenceFlow id="flow_still_open" name="still open" sourceRef="disposition_decision" targetRef="await_operator_resume" />
    <bpmn:sequenceFlow id="flow_resume_disposition" sourceRef="await_operator_resume" targetRef="disposition_entry" />
    <bpmn:sequenceFlow id="flow_rejected" name="rejected" sourceRef="disposition_decision" targetRef="change_rejected" />
    <bpmn:sequenceFlow id="flow_merged" name="merged" sourceRef="disposition_decision" targetRef="sync_primary_after_merge" />
    <bpmn:sequenceFlow id="flow_sync_conformance" sourceRef="sync_primary_after_merge" targetRef="record_conformance" />
    <bpmn:sequenceFlow id="flow_conformance_done" sourceRef="record_conformance" targetRef="git_reconciled" />
  </bpmn:process>
</bpmn:definitions>
