<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="post_merge_main_sync_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="post_merge_main_sync" name="Synchronize primary main after browser merges" isExecutable="false">
    <bpmn:startEvent id="scope_approved" name="Safe post-merge synchronization approved">
      <bpmn:documentation>The operator approved a guarded post-merge synchronization responsibility. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:22-30,46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="22-30,46" />
      </bpmn:extensionElements>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="update_skill" name="Update deliver-change lifecycle">
      <bpmn:documentation>Add primary-main synchronization after a verified merged disposition, with explicit refusal boundaries. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:27-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="27-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="verification_entry" name="Enter verification">
      <bpmn:documentation>Join initial implementation and corrected-review paths before rerunning validation. Evidence: skills/code-review/SKILL.md:79-87</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="79-87" />
      </bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f2a</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="validate_skill" name="Validate Skill structure">
      <bpmn:documentation>Run the Skill validator and diff hygiene checks. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:30-30</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="30-30" />
      </bpmn:extensionElements>
      <bpmn:incoming>f2a</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="check_safety_paths" name="Check success and refusal paths">
      <bpmn:documentation>Verify the procedure covers clean synchronization, dirty checkout, absent main checkout, branch mismatch, non-fast-forward state, and final SHA equality. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:27-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="27-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="review_change" name="Run fresh-context review">
      <bpmn:documentation>Delegate an independent read-only review after local verification. Evidence: skills/deliver-change/SKILL.md:26-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="26-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="review_decision" name="Change green?">
      <bpmn:documentation>Decide whether verified material findings remain. Evidence: skills/code-review/SKILL.md:72-77</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="72-77" />
      </bpmn:extensionElements>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_findings" name="Fix in-scope findings">
      <bpmn:documentation>Apply only the smallest causal corrections within the agreed responsibility. Evidence: skills/code-review/SKILL.md:79-87</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="79-87" />
      </bpmn:extensionElements>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="finalize_task" name="Finalize TASK-14">
      <bpmn:documentation>Check acceptance criteria, record the final summary, and mark the Task Done in the Change. Evidence: skills/deliver-change/SKILL.md:32-37</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="32-37" />
      </bpmn:extensionElements>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="publish_change" name="Commit, push, and open PR">
      <bpmn:documentation>Publish the reviewed green Change and pass final GitHub checks. Evidence: skills/deliver-change/SKILL.md:29-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="29-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="operator_review" name="Operator reviews PR">
      <bpmn:documentation>The operator retains merge authority and chooses the pull-request disposition. Evidence: skills/deliver-change/SKILL.md:46-62</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="46-62" />
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="disposition_entry" name="Enter disposition check">
      <bpmn:documentation>Join the initial and resumed operator-disposition observations before branching on PR state. Evidence: skills/deliver-change/SKILL.md:60-69</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="60-69" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f11a</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="disposition_decision" name="PR disposition?">
      <bpmn:documentation>Branch on merged, rejected, or still-open state observed from GitHub. Evidence: skills/deliver-change/SKILL.md:60-69</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="60-69" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11a</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:outgoing>f14</bpmn:outgoing>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="await_disposition" name="Await later disposition">
      <bpmn:documentation>Stop and resume only when the operator later changes the PR state. Evidence: skills/deliver-change/SKILL.md:60-64</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="60-64" />
      </bpmn:extensionElements>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="change_rejected" name="Change rejected">
      <bpmn:documentation>Report rejection without synchronizing primary main. Evidence: skills/deliver-change/SKILL.md:63-69</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="63-69" />
      </bpmn:extensionElements>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="locate_primary" name="Locate primary main checkout">
      <bpmn:documentation>Resolve the single worktree whose branch is refs/heads/main after the PR is verified merged. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:27-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="27-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="primary_safe" name="Primary checkout safe?">
      <bpmn:documentation>Require exactly one main checkout, a clean working tree, main checked out, and a fast-forwardable remote state. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:28-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="28-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="report_unsafe" name="Synchronization refused">
      <bpmn:documentation>Leave repository state untouched and report the failed safety condition. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:28-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="28-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="fast_forward_main" name="Fast-forward primary main">
      <bpmn:documentation>Run the explicit fast-forward-only synchronization against origin/main. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:27-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="27-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="verify_main" name="Verify main matches remote">
      <bpmn:documentation>Compare local main with the fetched origin/main and observe the updated Backlog board input files. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:29-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="29-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="sha_match" name="SHAs match?">
      <bpmn:documentation>Treat exact local and fetched remote SHA equality as the synchronization success condition. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:29-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="29-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="report_mismatch" name="Verification failed">
      <bpmn:documentation>Report the observed mismatch and do not claim synchronization. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:28-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="28-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="record_conformance" name="Record plan conformance">
      <bpmn:documentation>After landing, account for every planned task and gateway against execution evidence. Evidence: skills/bpmn-plans/SKILL.md:66-77</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="66-77" />
      </bpmn:extensionElements>
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="board_current" name="Primary main and board current">
      <bpmn:documentation>The landed Change is present in primary main and local Backlog watchers can render it. Evidence: backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md:22-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-14 - Synchronize-primary-main-after-browser-merges.md" lines="22-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f23</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="scope_approved" targetRef="update_skill" />
    <bpmn:sequenceFlow id="f2" sourceRef="update_skill" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="f2a" sourceRef="verification_entry" targetRef="validate_skill" />
    <bpmn:sequenceFlow id="f3" sourceRef="validate_skill" targetRef="check_safety_paths" />
    <bpmn:sequenceFlow id="f4" sourceRef="check_safety_paths" targetRef="review_change" />
    <bpmn:sequenceFlow id="f5" sourceRef="review_change" targetRef="review_decision" />
    <bpmn:sequenceFlow id="f6" name="findings" sourceRef="review_decision" targetRef="fix_findings" />
    <bpmn:sequenceFlow id="f7" sourceRef="fix_findings" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="f8" name="green" sourceRef="review_decision" targetRef="finalize_task" />
    <bpmn:sequenceFlow id="f9" sourceRef="finalize_task" targetRef="publish_change" />
    <bpmn:sequenceFlow id="f10" sourceRef="publish_change" targetRef="operator_review" />
    <bpmn:sequenceFlow id="f11" sourceRef="operator_review" targetRef="disposition_entry" />
    <bpmn:sequenceFlow id="f11a" sourceRef="disposition_entry" targetRef="disposition_decision" />
    <bpmn:sequenceFlow id="f12" name="open" sourceRef="disposition_decision" targetRef="await_disposition" />
    <bpmn:sequenceFlow id="f13" sourceRef="await_disposition" targetRef="disposition_entry" />
    <bpmn:sequenceFlow id="f14" name="rejected" sourceRef="disposition_decision" targetRef="change_rejected" />
    <bpmn:sequenceFlow id="f15" name="merged" sourceRef="disposition_decision" targetRef="locate_primary" />
    <bpmn:sequenceFlow id="f16" sourceRef="locate_primary" targetRef="primary_safe" />
    <bpmn:sequenceFlow id="f17" name="no" sourceRef="primary_safe" targetRef="report_unsafe" />
    <bpmn:sequenceFlow id="f18" name="yes" sourceRef="primary_safe" targetRef="fast_forward_main" />
    <bpmn:sequenceFlow id="f19" sourceRef="fast_forward_main" targetRef="verify_main" />
    <bpmn:sequenceFlow id="f20" sourceRef="verify_main" targetRef="sha_match" />
    <bpmn:sequenceFlow id="f21" name="no" sourceRef="sha_match" targetRef="report_mismatch" />
    <bpmn:sequenceFlow id="f22" name="yes" sourceRef="sha_match" targetRef="record_conformance" />
    <bpmn:sequenceFlow id="f23" sourceRef="record_conformance" targetRef="board_current" />
  </bpmn:process>
</bpmn:definitions>
