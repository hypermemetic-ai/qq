<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="one_pr_bpmn_conformance_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="one_pr_bpmn_conformance" name="Keep BPMN conformance inside the owning PR" isExecutable="false">
    <bpmn:startEvent id="scope_approved" name="One-PR conformance scope approved">
      <bpmn:documentation>Historical records remain intact; the procedure changes prospectively to same-PR closeout. Evidence: backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md:19-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md" lines="19-29" />
      </bpmn:extensionElements>
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="update_skill" name="Update bpmn-plans boundary">
      <bpmn:documentation>Make plans end at green PR handoff and move conformance plus Task finalization into same-PR closeout metadata. Evidence: backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md:24-27</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md" lines="24-27" />
      </bpmn:extensionElements>
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="verification_entry" name="Enter verification">
      <bpmn:documentation>Join initial implementation and corrected-delta paths before rerunning all affected checks. Evidence: skills/code-review/SKILL.md:78-83</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-83" />
      </bpmn:extensionElements>
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="validate_skill" name="Validate Skill and metadata">
      <bpmn:documentation>Run the Skill validator, parse interface metadata, and inspect trigger/procedure coherence. Evidence: backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md:28-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md" lines="28-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="forward_test" name="Exercise one-PR closeout">
      <bpmn:documentation>Use fresh contexts to test same-PR conformance, changed-after-conformance, and disposition exclusions. Evidence: backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md:24-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md" lines="24-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="review_change" name="Run fresh-context review">
      <bpmn:documentation>Delegate independent read-only review of the exact implementation and plan artifacts. Evidence: skills/deliver-change/SKILL.md:26-28</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="26-28" />
      </bpmn:extensionElements>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="review_decision" name="Implementation green?">
      <bpmn:documentation>Branch on whether verified material findings remain. Evidence: skills/code-review/SKILL.md:72-83</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="72-83" />
      </bpmn:extensionElements>
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_findings" name="Fix in-scope findings">
      <bpmn:documentation>Apply only the smallest causal corrections and rerun affected checks. Evidence: skills/code-review/SKILL.md:78-83</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-83" />
      </bpmn:extensionElements>
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="publish_pr" name="Publish the owning PR">
      <bpmn:documentation>Commit the reviewed planned work, push it, and open its one owning pull request. Evidence: skills/deliver-change/SKILL.md:29-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="29-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="pr_decision" name="Owning PR green?">
      <bpmn:documentation>Use applicable GitHub checks and mergeability as the planned handoff gate. Evidence: skills/deliver-change/SKILL.md:29-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="29-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_pr_failure" name="Correct failed PR checks">
      <bpmn:documentation>Correct only in-scope failures and return through validation and review before republishing. Evidence: skills/deliver-change/SKILL.md:38-45</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="38-45" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="green_pr_handoff" name="Change green for PR handoff">
      <bpmn:documentation>The planned implementation is green in its owning PR. Conformance and Task finalization are same-PR closeout metadata outside the BPMN nodes. Evidence: backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md:24-27</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-15 - Keep-BPMN-conformance-inside-the-owning-PR.md" lines="24-27" />
      </bpmn:extensionElements>
      <bpmn:incoming>f13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="scope_approved" targetRef="update_skill" />
    <bpmn:sequenceFlow id="f2" sourceRef="update_skill" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="f3" sourceRef="verification_entry" targetRef="validate_skill" />
    <bpmn:sequenceFlow id="f4" sourceRef="validate_skill" targetRef="forward_test" />
    <bpmn:sequenceFlow id="f5" sourceRef="forward_test" targetRef="review_change" />
    <bpmn:sequenceFlow id="f6" sourceRef="review_change" targetRef="review_decision" />
    <bpmn:sequenceFlow id="f7" name="findings" sourceRef="review_decision" targetRef="fix_findings" />
    <bpmn:sequenceFlow id="f8" sourceRef="fix_findings" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="f9" name="green" sourceRef="review_decision" targetRef="publish_pr" />
    <bpmn:sequenceFlow id="f10" sourceRef="publish_pr" targetRef="pr_decision" />
    <bpmn:sequenceFlow id="f11" name="not green" sourceRef="pr_decision" targetRef="fix_pr_failure" />
    <bpmn:sequenceFlow id="f12" sourceRef="fix_pr_failure" targetRef="verification_entry" />
    <bpmn:sequenceFlow id="f13" name="green" sourceRef="pr_decision" targetRef="green_pr_handoff" />
  </bpmn:process>
</bpmn:definitions>
