        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_fix_verification" sourceRef="fix_pr_failures" targetRef="verification_entry">
      <bpmn:documentation>PR corrections repeat every required local and independent Check before another handoff. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_handoff" name="yes" sourceRef="pr_green" targetRef="green_handoff">
