    <bpmn:sequenceFlow id="flow_tune_verification" sourceRef="tune_generation_capability" targetRef="verification_entry">
      <bpmn:documentation>Every behavioral adjustment repeats mechanical checks and the real internal-agent smoke run. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_helpful_review" name="yes" sourceRef="diagram_helpful" targetRef="fresh_context_review">
      <bpmn:documentation>A useful, verified internal-generation result advances to independent review. Evidence: skills/code-review/SKILL.md:44-68</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="44-68" />
      </bpmn:extensionElements>
