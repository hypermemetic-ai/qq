<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="task6_openwiki_internal_bpmn_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="task6_openwiki_internal_bpmn" name="Teach OpenWiki generation to author helpful BPMN" isExecutable="false">
    <bpmn:startEvent id="intent_recovered" name="Internal-generator intent recovered">
      <bpmn:documentation>Resume the operator-settled outcome: OpenWiki internal generation authors useful BPMN alongside Markdown; the outer maintainer only invokes, verifies, and delivers. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_seam</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="confirm_extension_seam" name="Confirm internal-agent extension seam">
      <bpmn:documentation>Verify how qq-openwiki forwards caller input into the installed OpenWiki update and how the existing wrapper and tests preserve its run boundary. Evidence: bin/qq-openwiki:10-17,158-172</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="bin/qq-openwiki" lines="10-17,158-172" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_seam</bpmn:incoming>
      <bpmn:outgoing>flow_seam_command</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="build_wiki_publish_command" name="Build reliable wiki publish command">
      <bpmn:documentation>Expose the locked pipeline as one internal-agent-friendly command that requires complete node and edge evidence, deterministic generation, the matching semantic BPMN, and the visibly attributed PNG without publishing intermediate SVG output. Evidence: skills/bpmn-plans/pipeline/README.md:1-7,37-52,169-197</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/pipeline/README.md" lines="1-7,37-52,169-197" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_seam_command</bpmn:incoming>
      <bpmn:outgoing>flow_command_guidance</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="inject_generator_guidance" name="Teach generator when and how to diagram">
      <bpmn:documentation>Have qq-openwiki supply stable guidance to the internal OpenWiki agent: choose BPMN only where it materially clarifies a process, author it with the Markdown, embed the PNG, maintain existing diagrams, and impose no prescribed diagram or quota while preserving caller instructions. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_command_guidance</bpmn:incoming>
      <bpmn:outgoing>flow_guidance_install</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="install_and_document_tool" name="Install and document generator tool">
      <bpmn:documentation>Make the reusable publication command available to OpenWiki runs through the existing qq installer and document the internal generation contract at its source-owned surfaces. Evidence: bin/install.sh:124-147</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="bin/install.sh" lines="124-147" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_guidance_install</bpmn:incoming>
      <bpmn:outgoing>flow_install_verification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="verification_entry" name="Verification entry">
      <bpmn:documentation>Merge the initial implementation and all in-scope correction paths before re-running the complete focused verification sequence. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_install_verification</bpmn:incoming>
      <bpmn:incoming>flow_check_fix_verification</bpmn:incoming>
      <bpmn:incoming>flow_tune_verification</bpmn:incoming>
      <bpmn:incoming>flow_review_fix_verification</bpmn:incoming>
      <bpmn:incoming>flow_pr_fix_verification</bpmn:incoming>
      <bpmn:outgoing>flow_verification_checks</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="run_automated_checks" name="Run pipeline, wrapper, and installer checks">
      <bpmn:documentation>Exercise wiki publication, evidence refusal, deterministic output, message and option preservation, installation, existing wrapper invariants, and the rendering-enabled pipeline suite. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:35-47</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="35-47" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_verification_checks</bpmn:incoming>
      <bpmn:outgoing>flow_checks_gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_green" name="Automated checks green?">
      <bpmn:documentation>Only a mechanically verified capability advances to the real internal-agent smoke run. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_gate</bpmn:incoming>
      <bpmn:outgoing>flow_checks_fail</bpmn:outgoing>
      <bpmn:outgoing>flow_checks_smoke</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_check_failures" name="Fix in-scope check failures">
      <bpmn:documentation>Correct the smallest causal implementation defect and return through the complete focused checks. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_fail</bpmn:incoming>
      <bpmn:outgoing>flow_check_fix_verification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="run_internal_agent_smoke" name="Run real internal OpenWiki smoke test">
      <bpmn:documentation>Run the installed OpenWiki internal generator against a disposable repository containing a diagram-worthy process; do not invoke the outer maintainer or directly author the generated wiki. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_smoke</bpmn:incoming>
      <bpmn:outgoing>flow_smoke_assess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="assess_generated_wiki" name="Judge generated diagram usefulness">
      <bpmn:documentation>Inspect whether the internal agent actually selected a worthwhile process, produced an accurate readable diagram, and used it to clarify rather than decorate or replace the Markdown narrative. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:21-32,44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="21-32,44-53" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_smoke_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_gate</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="diagram_helpful" name="Helpful BPMN generated?">
      <bpmn:documentation>The capability succeeds only when a real diagram-worthy generation run produces useful embedded BPMN, not merely when prompt text and commands exist. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:36-46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="36-46" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_assess_gate</bpmn:incoming>
      <bpmn:outgoing>flow_helpful_tune</bpmn:outgoing>
      <bpmn:outgoing>flow_helpful_review</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="tune_generation_capability" name="Tune tool or generator guidance">
      <bpmn:documentation>If the internal agent omits a warranted diagram or produces an unhelpful one, adjust only the tool or guidance responsible and repeat mechanical and behavioral verification. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_helpful_tune</bpmn:incoming>
      <bpmn:outgoing>flow_tune_verification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="fresh_context_review" name="Run fresh-context review">
      <bpmn:documentation>Give the exact locally verified Change to an independent read-only reviewer before commit or publication. Evidence: skills/code-review/SKILL.md:44-68</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="44-68" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_helpful_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_findings</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="confirmed_findings" name="Confirmed findings?">
      <bpmn:documentation>The accountable agent verifies each reported failure path and changes only confirmed findings introduced within the agreed scope. Evidence: skills/code-review/SKILL.md:70-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review_findings</bpmn:incoming>
      <bpmn:outgoing>flow_findings_fix</bpmn:outgoing>
      <bpmn:outgoing>flow_findings_pr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_review_findings" name="Fix confirmed review findings">
      <bpmn:documentation>Apply the smallest in-scope correction and return through focused checks, behavioral smoke, and exact-delta review. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_findings_fix</bpmn:incoming>
      <bpmn:outgoing>flow_review_fix_verification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="open_source_pr" name="Open one source PR">
      <bpmn:documentation>Commit and push the green reviewed generator capability and open one pull request carrying TASK-6 intent and Check evidence. Evidence: skills/deliver-change/SKILL.md:37-45</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-45" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_findings_pr</bpmn:incoming>
      <bpmn:outgoing>flow_pr_gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="pr_green" name="PR green?">
      <bpmn:documentation>The source Change is ready only when its applicable GitHub checks pass and the demonstrated internal-generation behavior remains intact. Evidence: skills/deliver-change/SKILL.md:37-45,54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-45,54-58" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_gate</bpmn:incoming>
      <bpmn:outgoing>flow_pr_fail</bpmn:outgoing>
      <bpmn:outgoing>flow_pr_handoff</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_pr_failures" name="Fix in-scope PR failures">
      <bpmn:documentation>Correct an in-scope handoff failure and return through local verification, internal-agent smoke, and fresh review. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_fail</bpmn:incoming>
      <bpmn:outgoing>flow_pr_fix_verification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="green_handoff" name="Internal-generation PR green">
      <bpmn:documentation>TASK-6 reaches a green source-PR handoff with the internal OpenWiki agent proven able to choose and author helpful BPMN alongside Markdown. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:35-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="35-53" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_handoff</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_seam" sourceRef="intent_recovered" targetRef="confirm_extension_seam">
      <bpmn:documentation>The recovered boundary is grounded in the actual internal-agent extension seam before code changes begin. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_seam_command" sourceRef="confirm_extension_seam" targetRef="build_wiki_publish_command">
      <bpmn:documentation>The confirmed update-message seam is paired with a reliable tool the internal agent can invoke. Evidence: bin/qq-openwiki:158-172</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="bin/qq-openwiki" lines="158-172" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_command_guidance" sourceRef="build_wiki_publish_command" targetRef="inject_generator_guidance">
      <bpmn:documentation>The internal agent is taught to use the publication command only when BPMN adds explanatory value. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_guidance_install" sourceRef="inject_generator_guidance" targetRef="install_and_document_tool">
      <bpmn:documentation>The generation contract and its command must be available together in installed qq environments. Evidence: bin/install.sh:124-147</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="bin/install.sh" lines="124-147" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_install_verification" sourceRef="install_and_document_tool" targetRef="verification_entry">
      <bpmn:documentation>The coherent implementation unit enters the common verification loop. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_verification_checks" sourceRef="verification_entry" targetRef="run_automated_checks">
      <bpmn:documentation>Initial implementation and every correction use the same focused mechanical checks. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_gate" sourceRef="run_automated_checks" targetRef="checks_green">
      <bpmn:documentation>Observed automated results determine whether real internal-agent generation can begin. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_fail" name="no" sourceRef="checks_green" targetRef="fix_check_failures">
