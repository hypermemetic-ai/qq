    <bpmn:sequenceFlow id="flow_review_findings" sourceRef="fresh_context_review" targetRef="confirmed_findings">
      <bpmn:documentation>The accountable agent verifies every material review report against the exact Change. Evidence: skills/code-review/SKILL.md:70-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_findings_fix" name="yes" sourceRef="confirmed_findings" targetRef="fix_review_findings">
