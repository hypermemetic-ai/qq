      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_review_fix_verification" sourceRef="fix_review_findings" targetRef="verification_entry">
