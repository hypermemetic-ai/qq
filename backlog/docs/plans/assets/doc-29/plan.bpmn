    <bpmn:sequenceFlow id="flow_pr_gate" sourceRef="open_source_pr" targetRef="pr_green">
      <bpmn:documentation>The published Change must pass its applicable GitHub checks before handoff. Evidence: skills/deliver-change/SKILL.md:37-45,54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-45,54-58" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_fail" name="no" sourceRef="pr_green" targetRef="fix_pr_failures">
      <bpmn:documentation>An in-scope PR failure returns to implementation verification and review. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
