      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_check_fix_verification" sourceRef="fix_check_failures" targetRef="verification_entry">
      <bpmn:documentation>Every check correction returns through the complete focused suite. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_smoke" name="yes" sourceRef="checks_green" targetRef="run_internal_agent_smoke">
      <bpmn:documentation>Green mechanics advance to a real OpenWiki internal-generation run. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:44-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="44-53" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_smoke_assess" sourceRef="run_internal_agent_smoke" targetRef="assess_generated_wiki">
      <bpmn:documentation>The generated files and page are inspected for actual explanatory quality, not mere existence. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:36-46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="36-46" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_assess_gate" sourceRef="assess_generated_wiki" targetRef="diagram_helpful">
      <bpmn:documentation>The qualitative verdict controls whether the capability is ready for independent review. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:36-46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="36-46" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_helpful_tune" name="no" sourceRef="diagram_helpful" targetRef="tune_generation_capability">
      <bpmn:documentation>Missing, decorative, inaccurate, or unreadable BPMN requires an in-scope tool or guidance adjustment. Evidence: backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md:35-53</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-6 - Build-diagram-generation-skill-model-toolchain-selection.md" lines="35-53" />
