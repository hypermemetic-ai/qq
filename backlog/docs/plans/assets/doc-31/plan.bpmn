<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="task_22_openwiki_merge_plan_approval_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="task_22_openwiki_merge_plan_approval" name="Automate OpenWiki merge and make plan approval readable" isExecutable="false">
    <bpmn:startEvent id="plan_approved" name="Plan approved">
      <bpmn:documentation>Begin only after the stored task-specific diagram has been presented once and approved by the operator. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:40-44</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="40-44" />
      </bpmn:extensionElements>
      <bpmn:outgoing>f01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="implement_openwiki_merge" name="Automate guarded OpenWiki merge">
      <bpmn:documentation>Make the dedicated maintainer merge its own documentation-only pull request after final review, scope, and Check validation. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:29-30</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="29-30" />
      </bpmn:extensionElements>
      <bpmn:incoming>f01</bpmn:incoming>
      <bpmn:outgoing>f02</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="guard_current_target" name="Refuse stale generation targets">
      <bpmn:documentation>Require the generated target to remain current immediately before merge; regenerate or stop when main has advanced. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:29-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="29-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>f02</bpmn:incoming>
      <bpmn:outgoing>f03</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="preserve_operator_merge" name="Keep ordinary merge authority">
      <bpmn:documentation>Confine autonomous merge authority to OpenWiki maintenance so every ordinary Change remains operator-merged. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:30-30</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="30-30" />
      </bpmn:extensionElements>
      <bpmn:incoming>f03</bpmn:incoming>
      <bpmn:outgoing>f04</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="defer_plan_open" name="Move open to approval boundary">
      <bpmn:documentation>Finish generation, storage, linking, and verification before any plan viewer is opened. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:31-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="31-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f04</bpmn:incoming>
      <bpmn:outgoing>f05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="present_once" name="Open final plan exactly once">
      <bpmn:documentation>Present only the final plan version, once, alongside the explicit approval question; never present intermediate candidates. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:31-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="31-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f05</bpmn:incoming>
      <bpmn:outgoing>f06</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="retain_specific_detail" name="Retain task-specific detail">
      <bpmn:documentation>Keep every work-specific action, decision, failure path, and acceptance Check in the plan. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:32-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="32-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>f06</bpmn:incoming>
      <bpmn:outgoing>f07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="add_delivery_call" name="Add collapsed delivery call">
      <bpmn:documentation>Teach plan generation to represent inherited qq delivery as one reusable collapsed call activity instead of expanded invariant nodes. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:32-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="32-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>f07</bpmn:incoming>
      <bpmn:outgoing>f08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="wrap_plan_layout" name="Balance plan-only layout">
      <bpmn:documentation>Add deterministic plan-mode wrapping that keeps labels readable and the main flow traceable without flattening the diagram into a strip. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:33-33</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="33-33" />
      </bpmn:extensionElements>
      <bpmn:incoming>f08</bpmn:incoming>
      <bpmn:outgoing>f09</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="preserve_openwiki_layout" name="Preserve OpenWiki layout">
      <bpmn:documentation>Leave OpenWiki diagram publishing and its existing layout path unchanged while applying wrapping only to plan mode. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:33-33</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="33-33" />
      </bpmn:extensionElements>
      <bpmn:incoming>f09</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="add_focused_checks" name="Add policy and pipeline checks">
      <bpmn:documentation>Cover merge scope and freshness guards, exactly-once presentation, call activity generation, wrapped plan layout, determinism, and OpenWiki isolation. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:34-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="34-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="check_retry_join" name="Checks ready to run">
      <bpmn:documentation>Join the initial implementation path and either task-specific correction path before running one coherent focused Check suite. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:34-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="34-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f11a</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="run_behavior_checks" name="Run focused behavior checks">
      <bpmn:documentation>Run the affected Skill, BPMN pipeline, layout, rendering, determinism, and isolation Checks on the coherent Change. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:33-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="33-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f11a</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_green" name="Behavior checks green?">
      <bpmn:documentation>Decide whether the autonomous-merge safeguards and both plan-mode and OpenWiki-mode pipeline contracts pass their fresh Checks. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:29-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="29-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_in_scope_failure" name="Fix in-scope behavior failure">
      <bpmn:documentation>Correct the smallest causal implementation or test defect and rerun every affected focused Check. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:29-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="29-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="operator_uat" name="Review one final presentation">
      <bpmn:documentation>Have the operator observe one final approval presentation and judge its timing, uniqueness, legibility, and retained task-specific content. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:31-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="31-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="uat_accepted" name="Approval experience accepted?">
      <bpmn:documentation>Decide whether the single final presentation satisfies the operator-visible acceptance boundary. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:34-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="34-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_presentation" name="Fix rejected presentation">
      <bpmn:documentation>Correct an in-scope timing, duplication, layout, or content problem, then rerun the focused behavior Checks before presenting a new final version. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:31-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="31-34" />
      </bpmn:extensionElements>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="complete_qq_delivery" name="Complete qq Change delivery" calledElement="qq_change_delivery">
      <bpmn:documentation>Invoke the inherited qq delivery procedure only after every work-specific Check and acceptance step is complete; keep its invariant internals collapsed here. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:32-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="32-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="green_pr_ready" name="Green PR ready">
      <bpmn:documentation>End with the reviewed, verified Change green in its pull request and ready for operator disposition. Evidence: backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md:43-44</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-22 - Automate-OpenWiki-merge-and-make-plan-approval-readable.md" lines="43-44" />
      </bpmn:extensionElements>
      <bpmn:incoming>f20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f01" sourceRef="plan_approved" targetRef="implement_openwiki_merge" />
    <bpmn:sequenceFlow id="f02" sourceRef="implement_openwiki_merge" targetRef="guard_current_target" />
    <bpmn:sequenceFlow id="f03" sourceRef="guard_current_target" targetRef="preserve_operator_merge" />
    <bpmn:sequenceFlow id="f04" sourceRef="preserve_operator_merge" targetRef="defer_plan_open" />
    <bpmn:sequenceFlow id="f05" sourceRef="defer_plan_open" targetRef="present_once" />
    <bpmn:sequenceFlow id="f06" sourceRef="present_once" targetRef="retain_specific_detail" />
    <bpmn:sequenceFlow id="f07" sourceRef="retain_specific_detail" targetRef="add_delivery_call" />
    <bpmn:sequenceFlow id="f08" sourceRef="add_delivery_call" targetRef="wrap_plan_layout" />
    <bpmn:sequenceFlow id="f09" sourceRef="wrap_plan_layout" targetRef="preserve_openwiki_layout" />
    <bpmn:sequenceFlow id="f10" sourceRef="preserve_openwiki_layout" targetRef="add_focused_checks" />
    <bpmn:sequenceFlow id="f11" sourceRef="add_focused_checks" targetRef="check_retry_join" />
    <bpmn:sequenceFlow id="f11a" sourceRef="check_retry_join" targetRef="run_behavior_checks" />
    <bpmn:sequenceFlow id="f12" sourceRef="run_behavior_checks" targetRef="checks_green" />
    <bpmn:sequenceFlow id="f13" name="no" sourceRef="checks_green" targetRef="fix_in_scope_failure" />
    <bpmn:sequenceFlow id="f14" sourceRef="fix_in_scope_failure" targetRef="check_retry_join" />
    <bpmn:sequenceFlow id="f15" name="yes" sourceRef="checks_green" targetRef="operator_uat" />
    <bpmn:sequenceFlow id="f16" sourceRef="operator_uat" targetRef="uat_accepted" />
    <bpmn:sequenceFlow id="f17" name="no" sourceRef="uat_accepted" targetRef="fix_presentation" />
    <bpmn:sequenceFlow id="f18" sourceRef="fix_presentation" targetRef="check_retry_join" />
    <bpmn:sequenceFlow id="f19" name="yes" sourceRef="uat_accepted" targetRef="complete_qq_delivery" />
    <bpmn:sequenceFlow id="f20" sourceRef="complete_qq_delivery" targetRef="green_pr_ready" />
  </bpmn:process>
</bpmn:definitions>
