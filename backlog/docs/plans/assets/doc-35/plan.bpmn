<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="surface_retry_failed_openwiki_activations_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="surface_retry_failed_openwiki_activations" name="Surface and retry failed OpenWiki merge activations" isExecutable="false">
    <bpmn:startEvent id="start" name="Activation repair aligned">
      <bpmn:documentation>Begin from the operator-settled retry and notification behavior recorded in TASK-26. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:34-43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="34-43" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_approve</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="approve_plan" name="Confirm aligned activation plan">
      <bpmn:documentation>Confirm that the execution contract implements the settled TASK-26 outcome without broadening activation behavior. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:34-52</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="34-52" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_approve</bpmn:incoming>
      <bpmn:outgoing>flow_approve_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="plan_approved" name="Plan confirmed?">
      <bpmn:documentation>Proceed only while the diagram remains consistent with the already-aligned Task. Evidence: AGENTS.md:7-17</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="7-17" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_approve_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_plan_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_plan_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="return_alignment" name="Return to alignment">
      <bpmn:documentation>A material mismatch or new commitment returns to the assigning orchestrator before implementation. Evidence: AGENTS.md:7-17</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="7-17" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_plan_no</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="encode_failed_state" name="Encode retryable failed markers">
      <bpmn:documentation>Rewrite a marker to failed when dispatch raises after marker creation, retry only that explicit state, and retain successful dispatch dedupe. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:34-41</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="34-41" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_plan_yes</bpmn:incoming>
      <bpmn:outgoing>flow_state_errors</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="surface_activation_errors" name="Notify protocol ActivationErrors">
      <bpmn:documentation>Make the protocol-handler entry path raise a best-effort Herdr desktop notification for each surfaced ActivationError. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:35,42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="35,42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_state_errors</bpmn:incoming>
      <bpmn:outgoing>flow_errors_tests</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="add_regressions" name="Add retry and notification regressions">
      <bpmn:documentation>Extend the isolated activation harness so the old blackhole and silent-error behavior fails observably. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:40-43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="40-43" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_errors_tests</bpmn:incoming>
      <bpmn:outgoing>flow_tests_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_entry" name="Run or rerun verification">
      <bpmn:documentation>Join the initial implementation and in-scope repair paths before running the same fresh Checks. Evidence: openwiki/verification.md:8-13</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="openwiki/verification.md" lines="8-13" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_tests_entry</bpmn:incoming>
      <bpmn:incoming>flow_repair_entry</bpmn:incoming>
      <bpmn:outgoing>flow_entry_checks</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="run_checks" name="Run activation and repository Checks">
      <bpmn:documentation>Run the focused activation harness, static checks, repository harnesses, and diff hygiene against the changed behavior. Evidence: openwiki/verification.md:3-13,26-29</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="openwiki/verification.md" lines="3-13,26-29" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_entry_checks</bpmn:incoming>
      <bpmn:outgoing>flow_checks_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_green" name="Checks green?">
      <bpmn:documentation>Use fresh Check output to decide whether the implementation meets the Task or needs an in-scope repair. Evidence: AGENTS.md:22-24</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="22-24" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_checks_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_checks_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="repair" name="Repair in-scope failures">
      <bpmn:documentation>Apply the smallest causal correction for a failed Task-specific Check, then rerun the same evidence path. Evidence: AGENTS.md:18-24</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="18-24" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_no</bpmn:incoming>
      <bpmn:outgoing>flow_repair_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="verify_acceptance" name="Verify all four acceptance criteria">
      <bpmn:documentation>Confirm failed dispatch retry, completed dispatch dedupe, ActivationError notification, and focused regression coverage from fresh results. Evidence: backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md:40-43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-26 - Surface-and-retry-failed-OpenWiki-merge-activations.md" lines="40-43" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_yes</bpmn:incoming>
      <bpmn:outgoing>flow_acceptance_delivery</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="complete_delivery" name="Complete qq Change delivery" calledElement="qq_change_delivery">
      <bpmn:documentation>Invoke the inherited reviewed, checked, finalized, one-PR delivery procedure. Evidence: skills/bpmn-plans/SKILL.md:24-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="24-42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_acceptance_delivery</bpmn:incoming>
      <bpmn:outgoing>flow_delivery_green</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="green_pr" name="Green PR ready">
      <bpmn:documentation>End when the reviewed activation repair is green and ready for operator disposition. Evidence: skills/bpmn-plans/SKILL.md:34-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="34-42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_delivery_green</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_approve" sourceRef="start" targetRef="approve_plan" />
    <bpmn:sequenceFlow id="flow_approve_gateway" sourceRef="approve_plan" targetRef="plan_approved" />
    <bpmn:sequenceFlow id="flow_plan_yes" name="yes" sourceRef="plan_approved" targetRef="encode_failed_state" />
    <bpmn:sequenceFlow id="flow_plan_no" name="no" sourceRef="plan_approved" targetRef="return_alignment" />
    <bpmn:sequenceFlow id="flow_state_errors" sourceRef="encode_failed_state" targetRef="surface_activation_errors" />
    <bpmn:sequenceFlow id="flow_errors_tests" sourceRef="surface_activation_errors" targetRef="add_regressions" />
    <bpmn:sequenceFlow id="flow_tests_entry" sourceRef="add_regressions" targetRef="checks_entry" />
    <bpmn:sequenceFlow id="flow_entry_checks" sourceRef="checks_entry" targetRef="run_checks" />
    <bpmn:sequenceFlow id="flow_checks_gateway" sourceRef="run_checks" targetRef="checks_green" />
    <bpmn:sequenceFlow id="flow_checks_yes" name="yes" sourceRef="checks_green" targetRef="verify_acceptance" />
    <bpmn:sequenceFlow id="flow_checks_no" name="no" sourceRef="checks_green" targetRef="repair" />
    <bpmn:sequenceFlow id="flow_repair_entry" sourceRef="repair" targetRef="checks_entry" />
    <bpmn:sequenceFlow id="flow_acceptance_delivery" sourceRef="verify_acceptance" targetRef="complete_delivery" />
    <bpmn:sequenceFlow id="flow_delivery_green" sourceRef="complete_delivery" targetRef="green_pr" />
  </bpmn:process>
</bpmn:definitions>
