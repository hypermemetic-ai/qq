#!/bin/bash
# qq-gate-view — pane-local gate viewer. Attaches the no-mistakes TUI to the
# gate run for *this pane's branch*, and keeps doing so across successive runs.
#
# Why a wrapper instead of `no-mistakes attach`:
#   - bare `attach` resolves the *repo's* active run, not this worktree's. With
#     parallel workers, whichever run started last wins, so a pane can end up
#     watching another task's pipeline. We resolve the run id ourselves and pass
#     `attach --run <id>`.
#   - `axi status` is not reliably branch-scoped either: on a branch with no run
#     of its own it *falls back* to the repo's active run (verified 2026-07-08 —
#     a fresh worktree reported another task's run). So run ids come from the
#     branch-aware `axi` home view, then status is read with `--run`.
#   - a viewer usually spawns *before* its run exists (pane comes up with the
#     worker). Bare attach exits; this waits.
#   - a worker drives several runs (fix rounds, stacked slices). One attach
#     covers one run; this re-attaches to each new run for the branch.
#
# Detach (`q`) is respected: the viewer will not re-attach to a run you left,
# but it will pick up the next one. Ctrl-C exits the viewer entirely.
#
# Usage:
#   qq-gate-view [--interval SECONDS]        run the viewer in this pane
#   qq-gate-view --repo                      follow the repo's active run, any branch
#   qq-gate-view --spawn <pane_id> [--cwd P] attach a viewer beside that pane
#
# `--spawn` is the convention: any pane that drives gate runs gets a viewer as a
# right split (operator direction, 2026-07-08). It uses herdr's non-agent pane
# pattern (split + send-text + Enter), so the viewer never registers in the agent
# sidebar — that surface is reserved for actual agents.
set -uo pipefail

usage() {
  echo "usage: qq-gate-view [--interval SECONDS] [--repo] | --spawn <pane_id> [--cwd PATH] [--repo]" >&2
  exit 64
}

require_value() {
  local option="$1"
  local value="${2-}"
  [ -n "$value" ] && [[ "$value" != --* ]] && return
  echo "qq-gate-view: $option requires a value" >&2
  usage
}

validate_interval() {
  local value="$1"
  if [[ ! "$value" =~ ^([0-9]+([.][0-9]*)?|\.[0-9]+)$ ]] || ! awk -v value="$value" 'BEGIN { exit !(value + 0 > 0) }'; then
    echo "qq-gate-view: --interval must be a positive number of seconds" >&2
    exit 64
  fi
}

interval=5
spawn_pane="" spawn_cwd="" repo_scope=0
while [ $# -gt 0 ]; do
  case "$1" in
    --interval) require_value "$1" "${2-}"; interval="$2"; shift 2 ;;
    --spawn) require_value "$1" "${2-}"; spawn_pane="$2"; shift 2 ;;
    --cwd) require_value "$1" "${2-}"; spawn_cwd="$2"; shift 2 ;;
    --repo) repo_scope=1; shift ;;
    *) usage ;;
  esac
done

validate_interval "$interval"

if [ -n "$spawn_pane" ]; then
  command -v herdr >/dev/null || { echo "qq-gate-view: herdr not on PATH" >&2; exit 1; }
  self=$(readlink -f "$0")
  cwd=${spawn_cwd:-$(herdr pane get "$spawn_pane" 2>/dev/null | sed -n 's/.*"cwd":"\([^"]*\)".*/\1/p' | head -1)}
  [ -n "$cwd" ] || { echo "qq-gate-view: cannot resolve cwd for $spawn_pane (pass --cwd)" >&2; exit 1; }
  viewer=$(herdr pane split "$spawn_pane" --direction right --ratio 0.42 --cwd "$cwd" --no-focus 2>/dev/null \
           | sed -n 's/.*"pane_id":"\([^"]*\)".*/\1/p' | head -1)
  [ -n "$viewer" ] || { echo "qq-gate-view: split failed beside $spawn_pane" >&2; exit 1; }
  herdr pane rename "$viewer" "gate-view" >/dev/null 2>&1 || true
  [ "$repo_scope" = 1 ] && self="$self --repo"
  herdr pane send-text "$viewer" "$self" >/dev/null 2>&1 || { echo "qq-gate-view: cannot start viewer in $viewer" >&2; exit 1; }
  herdr pane send-keys "$viewer" Enter >/dev/null 2>&1 || { echo "qq-gate-view: cannot press Enter in $viewer" >&2; exit 1; }
  echo "$viewer"
  exit 0
fi

command -v no-mistakes >/dev/null || { echo "qq-gate-view: no-mistakes not on PATH" >&2; exit 1; }
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || { echo "qq-gate-view: not in a git repo" >&2; exit 1; }

# the backgrounded `attach` TUI, if one is running. Ctrl-C must take it with us:
# a targeted SIGINT (or an attach that ignores it) would otherwise orphan the TUI.
attach_pid=""
trap 'printf "\nqq-gate-view: exit\n"; [ -n "$attach_pid" ] && kill "$attach_pid" 2>/dev/null; exit 0' INT

detached_run=""
last_note=""

scope_label() { [ "$repo_scope" = 1 ] && echo "repo (any branch)" || echo "$branch"; }

note() { # print only when the message changes, so the pane stays readable
  [ "$1" = "$last_note" ] && return
  last_note="$1"
  printf '\033[2J\033[H'          # clear, home
  printf 'qq-gate-view · %s\n\n%s\n' "$(scope_label)" "$1"
}

is_live_status() {
  case "$1" in
    pending|running) return 0 ;;
    *) return 1 ;;
  esac
}

toon_field() {
  local key="$1"
  awk -v key="$key" '
    function clean(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      sub(/^"/, "", value)
      sub(/"$/, "", value)
      return value
    }
    $0 ~ "^[[:space:]]*(steps\\[|active_steps\\[|findings\\[|help\\[|gate:)" { exit }
    $0 ~ "^[[:space:]]*" key ":[[:space:]]*" {
      sub("^[[:space:]]*" key ":[[:space:]]*", "")
      print clean($0)
      exit
    }
  '
}

compact_output() {
  sed -n '1,4p' | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//' | cut -c1-500
}

gate_view_error() {
  local label="$1" rc="$2" output="$3" detail
  detail=$(printf '%s' "$output" | compact_output)
  printf 'gate_view_error: %s failed (exit %s)%s\n' "$label" "$rc" "${detail:+: $detail}"
}

axi_failed() {
  local rc="$1" output="$2"
  [ "$rc" -ne 0 ] && return 0
  grep -q '^error:' <<<"$output"
}

axi_home() {
  local out rc
  out=$(no-mistakes axi 2>&1)
  rc=$?
  if axi_failed "$rc" "$out"; then
    gate_view_error "no-mistakes axi" "$rc" "$out"
    return 1
  fi
  printf '%s' "$out"
}

axi_status() {
  local label="$1" out rc
  shift
  out=$(no-mistakes axi status "$@" 2>&1)
  rc=$?
  if axi_failed "$rc" "$out"; then
    gate_view_error "$label" "$rc" "$out"
    return 1
  fi
  printf '%s' "$out"
}

branch_run_id() {
  awk -v branch="$branch" '
    function clean(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      sub(/^"/, "", value)
      sub(/"$/, "", value)
      return value
    }
    function emit() {
      if (id != "" && (run_branch == "" || run_branch == branch)) {
        print id
        found = 1
        exit
      }
    }
    /^active_run:[[:space:]]*$/ {
      in_active = 1
      id = ""
      run_branch = ""
      next
    }
    in_active && /^[^[:space:]]/ {
      emit()
      in_active = 0
    }
    # a nested tabular block (steps[..], findings[..]) ends the scalar fields;
    # its rows must never be mistaken for the run id itself (cf. toon_field)
    in_active && /^[[:space:]]*(steps\[|active_steps\[|findings\[|help\[|gate:)/ {
      emit()
      in_active = 0
      next
    }
    in_active && /^[[:space:]]+id:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]+id:[[:space:]]*/, "", line)
      id = clean(line)
      next
    }
    in_active && /^[[:space:]]+branch:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]+branch:[[:space:]]*/, "", line)
      run_branch = clean(line)
      next
    }
    END {
      if (in_active && !found) emit()
    }
  '
}

branch_status() { # echo the axi status block only if it describes this branch
  local home run out reported
  if ! home=$(axi_home); then
    printf '%s' "$home"
    return 0
  fi
  run=$(branch_run_id <<<"$home")
  [ -n "$run" ] || return 0
  if ! out=$(axi_status "no-mistakes axi status --run $run" --run "$run"); then
    printf '%s' "$out"
    return 0
  fi
  reported=$(toon_field branch <<<"$out")
  [ "$reported" = "$branch" ] && printf '%s' "$out"
}

repo_run_id() { # id of whatever run the repo is driving, on any branch
  awk '/^(active_run|other_branch_active_run):[[:space:]]*$/ { want = 1; next }
       want && /^[[:space:]]+id:[[:space:]]*/ {
         line = $0
         sub(/^[[:space:]]+id:[[:space:]]*/, "", line)
         gsub(/"/, "", line)
         print line
         exit
       }
       want && /^[^[:space:]]/ { want = 0 }'
}

repo_status() { # a finished run must not mask a live one
  local home run out
  if ! home=$(axi_home); then
    printf '%s' "$home"
    return 0
  fi
  run=$(repo_run_id <<<"$home")
  if [ -n "$run" ]; then
    if ! out=$(axi_status "no-mistakes axi status --run $run" --run "$run"); then
      printf '%s' "$out"
      return 0
    fi
    printf '%s' "$out"
  else
    if ! out=$(axi_status "no-mistakes axi status"); then
      if grep -Eiq 'no (gate )?run|no active .*run|no run (yet|found)|no matching run|start a run' <<<"$out"; then
        return 0
      fi
      printf '%s' "$out"
      return 0
    fi
    printf '%s' "$out"
  fi
}

current_status() {
  if [ "$repo_scope" = 1 ]; then repo_status; else branch_status; fi
}

run_status_of() {
  local out
  out=$(no-mistakes axi status --run "$1" 2>/dev/null) || return 1
  toon_field status <<<"$out"
}

# `attach` parks on an end-screen when its run finishes, is cancelled, or is
# superseded — waiting for a keypress a viewer pane never gets. Supervise it:
# attach in the background, poll the run, reap the TUI on a terminal state.
# Without this the pane freezes on a dead run (observed 2026-07-08: a superseded
# run left the conductor's viewer on "Pipeline cancelled" while 3 runs were live).
attach_supervised() {
  local run="$1" st tui rc blind=0
  # A status query that ERRORS must not be read as "still live". `attach` never
  # self-exits on a dead run, so an unqueryable run (pruned, backend hiccup)
  # would loop here forever and freeze the pane — the very bug this supervises
  # against. Tolerate a few transient failures, then assume the run is gone.
  local blind_limit=5
  no-mistakes attach --run "$run" &
  tui=$!
  attach_pid="$tui"
  while kill -0 "$tui" 2>/dev/null; do
    if ! st=$(run_status_of "$run"); then
      blind=$((blind + 1))
      if [ "$blind" -ge "$blind_limit" ]; then
        kill "$tui" 2>/dev/null || true
        break
      fi
      sleep 3
      continue
    fi
    blind=0
    if ! is_live_status "$st"; then
      sleep 2                        # let the end-screen render, then reap
      kill "$tui" 2>/dev/null || true
      break
    fi
    sleep 3
  done
  wait "$tui" 2>/dev/null; rc=$?
  attach_pid=""
  return "$rc"
}

while true; do
  out=$(current_status)
  error=$(toon_field gate_view_error <<<"$out")
  if [ -n "$error" ]; then
    note "$error

fix no-mistakes setup, then this viewer will retry."
    sleep "$interval"
    continue
  fi
  run=$(toon_field id <<<"$out")
  status=$(toon_field status <<<"$out")

  if [ -z "$run" ]; then
    note "no gate run $([ "$repo_scope" = 1 ] && echo 'in this repo' || echo 'for this branch') yet — waiting.
hand work to the gate with:  no-mistakes axi run --skip ci --intent \"...\""
    sleep "$interval"
    continue
  fi

  if is_live_status "$status"; then
    if [ "$run" = "$detached_run" ]; then
      note "detached from $run (still ${status}) — waiting for the next run."
      sleep "$interval"
      continue
    fi
    last_note=""
    attach_supervised "$run"
    attach_status=$?
    # attach returned: either the run ended, or the operator pressed q.
    if ! out=$(axi_status "no-mistakes axi status --run $run" --run "$run"); then
      note "$(toon_field gate_view_error <<<"$out")

fix no-mistakes setup, then this viewer will retry."
      sleep "$interval"
      continue
    fi
    if [ "$repo_scope" != 1 ] && [ "$(toon_field branch <<<"$out")" != "$branch" ]; then out=""; fi
    status=$(toon_field status <<<"$out")
    if is_live_status "$status"; then
      if [ "$attach_status" -eq 0 ]; then
        detached_run="$run"
        sleep 1
      else
        note "attach to $run failed (exit $attach_status) while run is ${status} — retrying."
        sleep "$interval"
      fi
      continue
    fi
    sleep 1
  else
    # terminal run: keep its outcome on screen, wait for the branch's next run
    outcome=$(toon_field outcome <<<"$out")
    pr=$(toon_field pr <<<"$out")
    note "run $run — ${status}${outcome:+ (${outcome})}${pr:+
PR: $pr}

waiting for the next run on this branch."
    sleep "$interval"
  fi
done
