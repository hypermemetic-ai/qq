#!/usr/bin/env bash
# qq-herdr-snap — snap to the preferred orchestrator agent pane.
#
# Bound as a detached custom key (alt+o). First press jumps to the snap
# target: the Repository project home's pi agent, that home's claude fallback,
# the focused workspace's pi or claude agent when no home runtime exists, then
# the first focused-workspace agent in sidebar order.
# Pressing it again while already there bounces back to the pane you came
# from, so one key flips orchestrator<->elsewhere. State is keyed by the
# target workspace so bounce-back also works after a cross-space snap.
#
# Distinct from qq-herdr-home, which also requires a running Backlog-board
# pane; snap resolves the project home directly from workspace metadata.
#
# This only ever runs from a keybinding or an operator shell, so failures
# are best-effort notifications and the command exits successfully.
#
#   qq-herdr-snap            snap to orchestrator / bounce back
#   QQ_HERDR_SNAP_DRY=1 ...  print resolved panes and stop before focusing
set -euo pipefail

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
# shellcheck source=bin/lib/qq-bin.sh
source "$(dirname "$self")/lib/qq-bin.sh"
if ! qq_resolve_bin herdr; then
  printf 'qq-herdr-snap: %s\n' "$QQ_BIN_ERROR" >&2
  exit 0
fi
HERDR="$QQ_BIN_RESULT"

note() { "$HERDR" notification show "qq-snap" --body "$1" >/dev/null 2>&1 || true; }
die() {
  note "$1"
  exit 0
}

command -v jq >/dev/null 2>&1 || die "jq not found — required by qq-herdr-snap"

# Detached keybindings receive the pane where the key was pressed. Fall back
# to the calling terminal's pane when invoked manually.
current="${HERDR_PANE_ID:-}"
if [ -z "$current" ]; then
  current="$({ "$HERDR" pane current --current 2>/dev/null || true; } \
    | jq -r '.result.pane.pane_id // empty' 2>/dev/null)" || true
fi
[ -n "$current" ] || die "cannot resolve focused pane"

current_info="$({ "$HERDR" pane get "$current" 2>/dev/null || true; })"
workspace="$(jq -r '.result.pane.workspace_id // empty' <<<"$current_info" 2>/dev/null)" || true
[ -n "$workspace" ] || die "cannot resolve workspace of pane '$current'"

agents="$({ "$HERDR" agent list 2>/dev/null || true; })"
if ! jq -e '.result.agents | type == "array"' <<<"$agents" >/dev/null 2>&1; then
  die "cannot parse agent list"
fi

workspaces="$({ "$HERDR" workspace list 2>/dev/null || true; })"
if ! jq -e '.result.workspaces | type == "array"' \
  <<<"$workspaces" >/dev/null 2>&1; then
  die "cannot parse workspace list"
fi
if ! home_workspace="$(jq -r --arg ws "$workspace" '
  [
    .result.workspaces as $workspaces
    | $workspaces[]
    | select(.workspace_id == $ws and .worktree != null)
    | .worktree.repo_root as $repo_root
    | select($repo_root != null and $repo_root != "")
    | $workspaces[]
    | select(
        .worktree != null
        and .worktree.is_linked_worktree == false
        and .worktree.repo_root == $repo_root
      )
    | .workspace_id
  ][0] // empty
' <<<"$workspaces" 2>/dev/null)"; then
  die "cannot parse workspace list"
fi

if ! target_info="$(jq -r --arg ws "$workspace" --arg home "$home_workspace" '
  [.result.agents[] | select(.workspace_id == $ws)] as $focused
  | (
      ([.result.agents[]
        | select($home != "" and .workspace_id == $home and .agent == "pi")][0])
      // ([.result.agents[]
           | select($home != "" and .workspace_id == $home and .agent == "claude")][0])
      // ($focused | map(select(.agent == "pi")) | .[0])
      // ($focused | map(select(.agent == "claude")) | .[0])
      // $focused[0]
      // {}
    )
  | [((.agent == "pi") or (.agent == "claude")),
     (.pane_id // ""), (.workspace_id // "")]
  | @tsv
' <<<"$agents" 2>/dev/null)"; then
  die "cannot parse agent list"
fi
IFS=$'\t' read -r target_is_orchestrator target target_workspace <<<"$target_info"
[ -n "$target" ] || die "no agent session in this space"
[ -n "$target_workspace" ] || die "cannot resolve workspace of snap target '$target'"

state_file="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/qq-herdr-snap.$target_workspace.prev"

if [ -n "${QQ_HERDR_SNAP_DRY:-}" ]; then
  prev="$(head -n1 -- "$state_file" 2>/dev/null || true)"
  printf 'current=%s workspace=%s target=%s prev=%s\n' \
    "$current" "$workspace" "$target" "${prev:-none}"
  exit 0
fi

if [ "$current" != "$target" ]; then
  printf '%s\n' "$current" 2>/dev/null >"$state_file" || die "cannot record origin pane in '$state_file'"
  "$HERDR" agent focus "$target" >/dev/null 2>&1 || die "cannot focus orchestrator pane '$target'"
  exit 0
fi

# Already on the snap target: bounce back to the stored pane, if it still exists.
prev="$(head -n1 -- "$state_file" 2>/dev/null || true)"
if [ -z "$prev" ] || [ "$prev" = "$current" ]; then
  if [ "$target_is_orchestrator" = true ]; then
    die "already on the orchestrator"
  fi
  die "no other agent session in this space"
fi
prev_info="$({ "$HERDR" pane get "$prev" 2>/dev/null || true; })"
prev_tab="$(jq -r '.result.pane.tab_id // empty' <<<"$prev_info" 2>/dev/null)" || true
[ -n "$prev_tab" ] || die "previous pane is gone"
prev_agent="$(jq -r '.result.pane.agent // empty' <<<"$prev_info" 2>/dev/null)" || true
if [ -n "$prev_agent" ]; then
  "$HERDR" agent focus "$prev" >/dev/null 2>&1 || die "cannot focus previous pane '$prev'"
else
  # agent focus cannot target non-agent panes; tab focus restores the tab's
  # own remembered pane focus instead.
  "$HERDR" tab focus "$prev_tab" >/dev/null 2>&1 || die "cannot focus previous tab '$prev_tab'"
fi
