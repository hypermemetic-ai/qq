#!/usr/bin/env bash
# Publish or verify one evidence-backed OpenWiki BPMN model.
set -euo pipefail

die() {
  printf 'qq-openwiki-bpmn: %s\n' "$*" >&2
  exit 1
}

check=false
case "$#" in
  1)
    spec_argument="$1"
    ;;
  2)
    [ "$1" = "--check" ] \
      || die "usage: qq-openwiki-bpmn [--check] openwiki/processes/<id>.json"
    check=true
    spec_argument="$2"
    ;;
  *)
    die "usage: qq-openwiki-bpmn [--check] openwiki/processes/<id>.json"
    ;;
esac

command -v git >/dev/null 2>&1 || die "git not found"
if [ -n "${QQ_OPENWIKI_NODE_BIN:-}" ]; then
  case "$QQ_OPENWIKI_NODE_BIN" in
    /*) ;;
    *) die "QQ_OPENWIKI_NODE_BIN must be an absolute executable file" ;;
  esac
  if [ ! -f "$QQ_OPENWIKI_NODE_BIN" ] || [ ! -x "$QQ_OPENWIKI_NODE_BIN" ]; then
    die "QQ_OPENWIKI_NODE_BIN must be an absolute executable file"
  fi
  node_bin="$QQ_OPENWIKI_NODE_BIN"
else
  node_bin="$(command -v node 2>/dev/null || true)"
  [ -n "$node_bin" ] || die "node not found"
fi

root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a Git worktree"
root="$(cd "$root" && pwd -P)"
processes_directory="$root/openwiki/processes"
[ -d "$processes_directory" ] \
  || die "OpenWiki process directory is absent: $processes_directory"
if [ -L "$root/openwiki" ] || [ -L "$processes_directory" ]; then
  die "OpenWiki process directory must not be a symlink"
fi
processes_directory="$(cd "$processes_directory" && pwd -P)"
[ "$processes_directory" = "$root/openwiki/processes" ] \
  || die "OpenWiki process directory resolves outside the Repository"

spec_path="$(readlink -f -- "$spec_argument" 2>/dev/null || true)"
if [ -z "$spec_path" ] || [ ! -f "$spec_path" ]; then
  die "process spec is not a regular file: $spec_argument"
fi
[ "$(dirname "$spec_path")" = "$processes_directory" ] \
  || die "process spec must be a direct child of $processes_directory"
case "$(basename "$spec_path")" in
  *.json) ;;
  *) die "process spec must have a .json filename" ;;
esac

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
cli="$(cd "$(dirname "$self")/../skills/bpmn-plans/pipeline/bin" && pwd -P)/qq-bpmn.mjs"
[ -f "$cli" ] || die "bundled BPMN pipeline is missing: $cli"

arguments=("$cli" wiki "$spec_path")
[ "$check" = false ] || arguments+=(--check)
"$node_bin" "${arguments[@]}"
