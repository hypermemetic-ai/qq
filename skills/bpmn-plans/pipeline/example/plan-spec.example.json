{
  "id": "qq_release_plan",
  "name": "Prepare and approve a qq release",
  "elements": [
    {
      "id": "release_requested",
      "type": "startEvent",
      "name": "Release requested",
      "documentation": "A release work item has an agreed scope and acceptance criteria.",
      "evidence": {
        "file": "backlog/tasks/task-42 - prepare-qq-release.md",
        "lines": "8-19"
      }
    },
    {
      "id": "inspect_change",
      "type": "serviceTask",
