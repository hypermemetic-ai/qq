        "file": "backlog/docs/solutions/doc-17 - release-process.md",
        "lines": "41-56"
      }
    },
    {
      "id": "verify_release",
      "type": "serviceTask",
      "name": "Run release checks",
      "documentation": "Run the repository checks against the release candidate.",
