#!/usr/bin/env bash
set -euo pipefail

cat <<'USAGE'
Temporary adapter. Prefer the rented operator surface.

Usage:
  tools/fan-out units/U-*.md

For each queued unit, this prints a dispatch reminder. Replace this with the
native harness or Linear/Warp/Oz action as soon as it exists.
USAGE

for unit in "$@"; do
  [ -f "$unit" ] || continue
  if grep -Eq '^[-*]?[[:space:]]*\*\*Status:\*\*[[:space:]]*queued|^Status:[[:space:]]*queued' "$unit"; then
    echo "dispatch: $unit"
  fi
done
