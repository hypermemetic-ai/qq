#!/usr/bin/env python3
"""Run the first shell fenced block under a unit's Acceptance section."""
from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

SHELLS = {"sh", "bash", "shell", "zsh"}


def acceptance_script(text: str) -> str | None:
    in_acceptance = False
    in_fence = False
    fence = ""
    lines: list[str] = []
    for line in text.splitlines():
        if not in_fence:
            heading = re.match(r"^(#{1,6})\s+(.+?)\s*$", line)
            if heading:
                title = heading.group(2).strip().lower()
                if title == "acceptance":
                    in_acceptance = True
                    continue
                if in_acceptance:
                    break
            if not in_acceptance:
                continue
            start = re.match(r"^\s*(```|~~~)\s*([A-Za-z0-9_-]*)\s*$", line)
            if start and start.group(2).lower() in SHELLS:
                in_fence = True
                fence = start.group(1)
                lines = []
            continue
        if re.match(rf"^\s*{re.escape(fence)}\s*$", line):
            return "\n".join(lines).strip() + "\n"
        lines.append(line)
    return None


def main(argv: list[str]) -> int:
    if len(argv) not in {2, 3} or (len(argv) == 3 and argv[2] != "--dry-run"):
        print("usage: tools/run-acceptance UNIT.md [--dry-run]", file=sys.stderr)
        return 2
    unit = Path(argv[1])
    script = acceptance_script(unit.read_text())
    if not script:
        print(f"{unit}: no shell fenced block found under Acceptance", file=sys.stderr)
        return 2
    print(f"acceptance: {unit}")
    if argv[-1] == "--dry-run":
        print(script, end="")
        return 0
    return subprocess.run(["bash", "-euo", "pipefail"], input=script, text=True).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
