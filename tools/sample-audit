#!/usr/bin/env bash
set -euo pipefail

RATE=${RATE:-10}
if ! [[ "$RATE" =~ ^[0-9]+$ ]] || [ "$RATE" -lt 0 ] || [ "$RATE" -gt 100 ]; then
  echo "RATE must be an integer from 0 to 100" >&2
  exit 2
fi

# Reads unit ids from stdin; prints sampled ids deterministically by hash.
while IFS= read -r s; do
  [ -z "$s" ] && continue
  h=$(printf '%s' "$s" | sha256sum | awk '{print $1}')
  n=$(( 0x$(printf %.4s "$h") ))
  [ $(( n % 100 )) -lt "$RATE" ] && echo "$s"
done
exit 0
